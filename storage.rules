rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Função helper para verificar se é admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }

    // Permitir leitura de qualquer coisa pública (avatares, materiais, vídeos)
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;
    }
    
    match /materials/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId && request.resource.size < 50 * 1024 * 1024;
    }

    // Permitir upload de fichas (PDFs) - apenas proprietários
    match /fichas/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId && request.resource.size < 100 * 1024 * 1024; // Max 100MB por ficha
    }

    // Permitir upload de vídeos - apenas utilizadores autenticados (admins podem fazer upload)
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 3 * 1024 * 1024 * 1024; // Max 3GB
    }

    // Permitir listagem de pastas para admins (raiz do storage)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 3 * 1024 * 1024 * 1024; // Max 3GB para uploads autenticados
    }
  }
}
